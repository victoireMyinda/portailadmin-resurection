rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Création anonyme (portail public) : champs obligatoires uniquement, sans id dans le document.
    function isValidVisitorMessage() {
      let data = request.resource.data;
      return data.keys().hasOnly(['name', 'phone', 'message', 'createdAt', 'read'])
        && data.name is string
        && data.name.size() >= 2
        && data.name.size() <= 120
        && data.phone is string
        && data.phone.size() >= 6
        && data.phone.size() <= 40
        && data.message is string
        && data.message.size() >= 10
        && data.message.size() <= 2000
        && data.createdAt is string
        && data.read is bool
        && data.read == false;
    }

    // Messages visiteurs : écriture publique (create), lecture/modif réservées aux admins connectés.
    match /visitorMessages/{messageId} {
      allow create: if isValidVisitorMessage();
      allow read, update, delete: if isSignedIn();
    }

    match /parishUsers/{userId} {
      allow read, write: if isSignedIn();
    }

    match /siteAnalytics/summary {
      allow read: if isSignedIn();
      allow create, update: if true;
    }

    match /{collection}/{docId} {
      allow read: if collection != 'visitorMessages' && collection != 'parishUsers' && collection != 'siteAnalytics';
      allow write: if isSignedIn();
    }
  }
}
